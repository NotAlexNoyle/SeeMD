Name:           seemd
Version:        @VERSION@
Release:        1%{?dist}
Summary:        Lightweight GTK3 markdown viewer

License:        MIT
URL:            @URL@
Source0:        seemd-%{version}.tar.gz

BuildRequires:  gcc
BuildRequires:  make
BuildRequires:  pkgconfig
BuildRequires:  gtk3-devel
BuildRequires:  webkit2gtk4.1-devel

Requires:       gtk3
Requires:       webkit2gtk4.1

%description
SeeMD is a lightweight GTK3 markdown viewer with GitHub-style WebKit preview rendering.

%prep
%autosetup -n seemd-%{version}

%build
make %{?_smp_mflags}

%install
rm -rf %{buildroot}
make install DESTDIR=%{buildroot} PREFIX=%{_prefix}

%files
%{_bindir}/seemd
%{_datadir}/applications/seemd.desktop

%changelog
* Thu Jan 01 1970 SeeMD Packager <noreply@example.com> - @VERSION@-1
- Initial package
